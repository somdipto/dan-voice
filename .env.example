# Copy to .env and fill in.

# Public hostname (Cloudflare Tunnel)
DOMAIN=voice.danlab.dev

# Local server port (server binds here, tunnel exposes it)
PORT=7860

# Cloudflare Tunnel — either a named-tunnel token (recommended) or leave blank for quick tunnel
# Get from: https://one.dash.cloudflare.com → Zero Trust → Networks → Tunnels
CLOUDFLARE_TUNNEL_TOKEN=

# Pairing URL TTL (seconds)
PAIRING_TTL_SECONDS=300

# Session token TTL (seconds)
SESSION_TTL_SECONDS=86400

# Auth signing key (256-bit, base64). Generate with: python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
# Leave blank to auto-generate per session (less safe; OK for local dev).
AUTH_SIGNING_KEY=

# Default adapter
DEFAULT_ADAPTER=claude_code

# STT model
WHISPER_MODEL=base.en

# TTS engine: kittentts | piper
TTS_ENGINE=kittentts

# Allowed origins for CORS (comma-separated). Empty = same-origin only.
ALLOWED_ORIGINS=

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
